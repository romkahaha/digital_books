{
  "schedule": {
    "enabled": false,
    "active_from": "08:00",
    "active_to": "23:00",
    "timezone": "Europe/Prague",
    "interval_minutes": 10,
    "github_actions_cron_utc": "disabled; run Reading cycle manually",
    "enforce_active_window": false
  },
  "preflight": {
    "require_monitor_items_py": true,
    "require_base_snapshot_csv": true,
    "require_risk_csv": true,
    "require_fit_json": true,
    "max_monitor_items_age_hours": 30.0,
    "max_base_snapshot_age_hours": 30.0,
    "max_risk_csv_age_hours": 36.0,
    "max_fit_json_age_hours": null,
    "fail_on_stale_inputs": false,
    "min_monitor_items": 1
  },
  "paths": {
    "monitor_items_py": "automation_runtime/monitor_list_latest.py",
    "state_json": "automation_runtime/state.json",
    "base_snapshot_csv": "automation_runtime/base_snapshot_latest.csv",
    "steam_listings_csv": "automation_runtime/steam_listings_latest.csv",
    "fit_json": "steam_listings/data/float_fit_rel_curves.json",
    "risk_csv": "automation_runtime/risk_metrics_latest.csv",
    "enriched_listings_csv": "automation_runtime/enriched_listings_latest.csv",
    "opportunities_csv": "automation_runtime/opportunities_latest.csv",
    "opportunities_report_csv": "automation_runtime/opportunities_report_latest.csv"
  },
  "monitoring": {
    "enabled": true,
    "batch_size": 5,
    "max_listings_per_item": 200,
    "fail_if_all_listing_fetches_error": true
  },
  "cycle": {
    "enabled": true,
    "batch_size": null,
    "cycle_sleep_sec": 600.0,
    "recoverable_error_sleep_sec": 5400.0,
    "commit_runtime": true,
    "commit_every_batches": 5,
    "max_runtime_minutes": 330.0,
    "max_batches_per_run": null,
    "max_cycles_per_run": null,
    "respect_active_window": false,
    "checkpoint_message": "Update monitoring runtime [skip ci]",
    "tiers": {
      "enabled": true,
      "queue_pattern": ["A", "A", "B", "A", "A", "B", "C"],
      "batch_sizes": {
        "A": 5,
        "B": 5,
        "C": 5
      },
      "max_listings_per_item": {
        "A": 100,
        "B": 200,
        "C": 200
      }
    }
  },
  "steam_scm": {
    "listings_per_request": 100,
    "max_listings_per_item": 200,
    "request_timeout_sec": 45.0,
    "retry_attempts": 3,
    "retry_sleep_min_sec": 2.0,
    "retry_sleep_max_sec": 5.0,
    "delay_between_skins_min_sec": 12.0,
    "delay_between_skins_max_sec": 24.0,
    "delay_between_render_pages_min_sec": 5.0,
    "delay_between_render_pages_max_sec": 10.0,
    "batch_log_progress": 1
  },
  "opportunity_filter": {
    "steam_sales_n_min": 50,
    "downside_risk_max": 10.0,
    "tail_ratio_min": 0.8,
    "downside_14d_max": 0.15,
    "continuity_ratio_max": 3.5,
    "spread_hybrid_disc_max": 0.12,
    "exclude_any": []
  },
  "alerts": {
    "enabled": true,
    "spread_hybrid_disc_max": 0.12,
    "ask_min": null,
    "ask_max": null,
    "steam_sales_7d_n_min": 50,
    "steam_sales_7d_downside_risk_max": 10.0,
    "steam_sales_7d_tail_ratio_min": 0.8,
    "steam_daily_downside_14d_pct_max": 0.15,
    "continuity_ratio_max": 3.5,
    "exclude_any": [
      "Fade",
      "Case Hardened",
      "Heat Treated"
    ]
  },
  "model_plot": {
    "enabled": true,
    "data_dir": "skin_homog/data_skins_big",
    "fit_json": "steam_listings/data/float_fit_rel_curves.json",
    "precomputed_dir": "automation_runtime/precomputed_fit_plots/skins_normal_filtered1",
    "dpi": 120,
    "write_precomputed_on_miss": true,
    "fail_on_error": false
  },
  "telegram": {
    "enabled": false,
    "cooldown_hours": 12.0,
    "sleep_sec": 0.6,
    "max_alerts": null,
    "send_empty_summary": false
  },
  "alert_enrichment": {
    "enabled": true,
    "background": true,
    "provider": "gemini",
    "gemini_model": "gemini-2.5-flash",
    "fee_pct": 0.02,
    "max_sales_rows": 30,
    "cache_ttl_minutes": 15.0,
    "use_stale_cache_on_error": true,
    "log_dir": "automation_runtime/alert_enrichment",
    "csfloat_timeout_sec": 30.0,
    "gemini_timeout_sec": 45.0,
    "telegram_timeout_sec": 20
  },
  "failover": {
    "enabled": true,
    "repo_path": "/home/roma/cs-arbitrage/digital_books",
    "remote_url": "git@github.com:romkahaha/digital_books.git",
    "branch": "main",
    "push_on_cycle_start": true,
    "request_on_rate_limit": true,
    "lease_seconds": 5400,
    "request_on_nightly_start": true,
    "nightly_lease_seconds": 19800,
    "copy_precomputed_plots": true
  }
}
